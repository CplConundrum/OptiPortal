Group #OptiPortalRoot {
  LayoutMode: Top;
  FlexWeight: 1;

  Group #MainBody {
    LayoutMode: Left;
    FlexWeight: 1;

    Group #LeftPanel {
      LayoutMode: Top;
      Anchor: (Width: 240, Top: 8, Bottom: 0, Left: 8, Right: 0);

      Label #ZoneListHeader {
        Style: (FontSize: 13, RenderBold: true);
        Anchor: (Horizontal: 4, Top: 0, Bottom: 8);
      }

      Group #ZoneList {
        LayoutMode: Top;
        FlexWeight: 1;
      }
    }

    Group #DetailPanel {
      LayoutMode: Top;
      FlexWeight: 1;
      Anchor: (Top: 8, Bottom: 0, Left: 16, Right: 8);

      Label #NoSelection {
        Style: (FontSize: 13);
        Anchor: (Horizontal: 0, Top: 80);
      }

      Group #ZoneDetail {
        LayoutMode: Top;

        Label #DetailName {
          Style: (FontSize: 17, RenderBold: true);
          Anchor: (Horizontal: 0, Bottom: 2);
        }

        Label #DetailMeta {
          Style: (FontSize: 11);
          Anchor: (Horizontal: 0, Bottom: 14);
        }

        Group #FieldStrategy {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 2, Bottom: 2);
          Label #Label { Style: (FontSize: 13); Anchor: (Width: 150); }
          Label #Value { Style: (FontSize: 13); }
        }

        Group #FieldRadius {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 2, Bottom: 2);
          Label #Label { Style: (FontSize: 13); Anchor: (Width: 150); }
          Label #Value { Style: (FontSize: 13); }
        }

        Group #FieldRadiusX {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 2, Bottom: 2);
          Label #Label { Style: (FontSize: 13); Anchor: (Width: 150); }
          Label #Value { Style: (FontSize: 13); }
        }

        Group #FieldRadiusZ {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 2, Bottom: 2);
          Label #Label { Style: (FontSize: 13); Anchor: (Width: 150); }
          Label #Value { Style: (FontSize: 13); }
        }

        Group #FieldActivation {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 2, Bottom: 2);
          Label #Label { Style: (FontSize: 13); Anchor: (Width: 150); }
          Label #Value { Style: (FontSize: 13); }
        }

        Group #FieldTTL {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 2, Bottom: 2);
          Label #Label { Style: (FontSize: 13); Anchor: (Width: 150); }
          Label #Value { Style: (FontSize: 13); }
        }

        Group #FieldShape {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 2, Bottom: 14);
          Label #Label { Style: (FontSize: 13); Anchor: (Width: 150); }
          Label #Value { Style: (FontSize: 13); }
        }

        Group #ActionButtons {
          LayoutMode: Left;
          Anchor: (Horizontal: 0, Top: 6, Bottom: 0);

          Label #FlushButton {
            Style: (FontSize: 13);
            Anchor: (Width: 90, Right: 8);
          }

          Label #DeleteButton {
            Style: (FontSize: 13);
            Anchor: (Width: 90);
          }
        }
      }
    }
  }

  Label #WarpStats {
    Style: (FontSize: 12);
    Anchor: (Horizontal: 12, Top: 8, Bottom: 6);
  }

  Label #StorageBackend {
    Style: (FontSize: 11);
    Anchor: (Horizontal: 12, Top: 4, Bottom: 12);
  }
}
