$C = "Common.ui";

$C.@Container {
  Anchor: (Width: 1000, Height: 720);

  #Title {
    Group {
      $C.@Title {
        @Text = "OptiPortal — Zone Cache Status";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Group #TableHeader {
      LayoutMode: Left;
      Anchor: (Horizontal: 12, Top: 12, Bottom: 8);

      Label #HdrTier {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 80);
      }
      Label #HdrName {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 180);
      }
      Label #HdrType {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 70);
      }
      Label #HdrStrat {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 70);
      }
      Label #HdrRadius {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 80);
      }
      Label #HdrRamMarginal {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 130);
      }
      Label #HdrPreload {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 70);
      }
      Label #HdrTTL {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 70);
      }
      Label #HdrStatus {
        Style: (FontSize: 16, RenderBold: true);
        Anchor: (Width: 90);
      }
    }

    Group #TableBody {
      LayoutMode: Left;
      Anchor: (Horizontal: 12, Top: 8, Bottom: 12);
      FlexWeight: 1;

      Label #ColTier {
        Style: (FontSize: 14);
        Anchor: (Width: 80);
      }
      Label #ColName {
        Style: (FontSize: 14);
        Anchor: (Width: 180);
      }
      Label #ColType {
        Style: (FontSize: 14);
        Anchor: (Width: 70);
      }
      Label #ColStrat {
        Style: (FontSize: 14);
        Anchor: (Width: 70);
      }
      Label #ColRadius {
        Style: (FontSize: 14);
        Anchor: (Width: 80);
      }
      Label #ColRamMarginal {
        Style: (FontSize: 14);
        Anchor: (Width: 130);
      }
      Label #ColPreload {
        Style: (FontSize: 14);
        Anchor: (Width: 70);
      }
      Label #ColTTL {
        Style: (FontSize: 14);
        Anchor: (Width: 70);
      }
      Label #ColStatus {
        Style: (FontSize: 14);
        Anchor: (Width: 90);
      }
    }

    Label #CommandRef1 {
      Style: (FontSize: 11);
      Anchor: (Horizontal: 12, Top: 12, Bottom: 4);
    }

    Label #CommandRef2 {
      Style: (FontSize: 11);
      Anchor: (Horizontal: 12, Top: 4, Bottom: 4);
    }

    Label #CommandRef3 {
      Style: (FontSize: 11);
      Anchor: (Horizontal: 12, Top: 4, Bottom: 8);
    }

    Label #WarpStats {
      Style: (FontSize: 12);
      Anchor: (Horizontal: 12, Top: 8, Bottom: 8);
    }

    Label #StorageBackend {
      Style: (FontSize: 11);
      Anchor: (Horizontal: 12, Top: 4, Bottom: 16);
    }
  }
}
